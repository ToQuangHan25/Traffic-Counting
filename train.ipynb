        },
        "id": "4mHTvdpNuEpo",
        "outputId": "e13b6ce9-d638-4608-842f-4a4106d1af02"
      },
      "outputs": [],
      "source": [
        "# ==========================================\n",
        "# BƯỚC 0: KẾT NỐI DRIVE & CÀI ĐẶT\n",
        "# ==========================================\n",
        "from google.colab import drive\n",
        "drive.mount('/content/drive') # Bắt buộc phải có để lưu kết quả an toàn\n",
        "\n",
        "!pip install ultralytics huggingface_hub -q\n",
        "\n",
        "# Bây giờ mới gọi thư viện\n",
        "from ultralytics import YOLO\n",
        "from huggingface_hub import login, hf_hub_download\n",
        "import os\n",
        "\n",
        "login(\"Nhập token")\n",
        "# ==========================================\n",
        "# BƯỚC 1: KÉO DỮ LIỆU TỪ HUGGING FACE\n",
        "# ==========================================\n",
        "REPO_ID = \"ToQuangHan/tsbow\"\n",
        "\n",
        "print(\"Đang tải tập Train...\")\n",
        "train_zip = hf_hub_download(repo_id=REPO_ID, filename=\"annotations_train.zip\", repo_type=\"dataset\")\n",
        "\n",
        "print(\"Đang tải tập Val...\")\n",
        "val_zip = hf_hub_download(repo_id=REPO_ID, filename=\"annotations_val.zip\", repo_type=\"dataset\")\n",
        "\n",
        "# ==========================================\n",
        "# BƯỚC 2: GIẢI NÉN VÀO CẤU TRÚC YOLO\n",
        "# ==========================================\n",
        "print(\"Đang giải nén dữ liệu...\")\n",
        "!mkdir -p /content/datasets/TSBOW/train\n",
        "!mkdir -p /content/datasets/TSBOW/val\n",
        "\n",
        "!unzip -o -q {train_zip} -d /content/datasets/TSBOW/train\n",
        "!unzip -o -q {val_zip} -d /content/datasets/TSBOW/val\n",
        "\n",
        "# ==========================================\n",
        "# BƯỚC 3: TẠO FILE TSBOW.YAML\n",
        "# ==========================================\n",
        "yaml_content = \"\"\"\n",
        "path: /content/datasets/TSBOW\n",
        "train: train\n",
        "val: val\n",
        "\n",
        "nc: 8\n",
        "names:\n",
        "  0: 'unidentified'\n",
        "  1: 'others'\n",
        "  2: 'pedestrian'\n",
        "  3: 'micromobility'\n",
        "  4: 'car'\n",
        "  5: 'bus'\n",
        "  6: 'small truck'\n",
        "  7: 'truck'\n",
        "\"\"\"\n",
        "with open('/content/datasets/TSBOW/TSBOW.yaml', 'w') as f:\n",
        "    f.write(yaml_content)\n",
        "\n",
        "print(\"Đã chuẩn bị xong Data!\")\n",
        "\n",
        "# ==========================================\n",
        "# BƯỚC 4: BẮT ĐẦU TRAINING\n",
        "# ==========================================\n",
        "output_dir = \"/content/drive/MyDrive/TSBOW_Results\"\n",
        "os.makedirs(output_dir, exist_ok=True)\n",
        "\n",
        "model = YOLO(\"yolo11m.pt\")\n",
        "\n",
        "print(\"🚀 Bắt đầu huấn luyện với ảnh 1280...\")\n",
        "\n",
        "results = model.train(\n",
        "    data=\"/content/datasets/TSBOW/TSBOW.yaml\",\n",
        "    epochs=50,\n",
        "\n",
        "    # --- THỬ NGHIỆM ĐỘ PHÂN GIẢI CAO NHẤT ---\n",
        "    imgsz=1280,              # Ép lên 1280 theo tác giả\n",
        "    batch=8,                # Hạ batch xuống cực thấp (4) để Colab không bị sập VRAM\n",
        "    workers=2,\n",
        "\n",
        "    patience=10,\n",
        "    device=\"0\",\n",
        "    project=output_dir,\n",
        "    name=\"tsbow_run\",\n",
        "    exist_ok=True,\n",
        "\n",
        "    # --- FINE-TUNING CHO THỜI TIẾT ---\n",
        "    lr0=0.001,\n",
        "    lrf=0.01,\n",
        "    freeze=10,\n",
        "\n",
        "    # --- TỐI ƯU AUGMENTATION ---\n",
        "    close_mosaic=10,\n",
        "    augment=True\n",
        ")"
      ]
    }
  ],
